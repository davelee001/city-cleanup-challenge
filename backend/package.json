{
  "name": "city-cleanup-backend",
  "version": "1.0.0",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon --quiet src/server.js",
    "health": "node scripts/health-check.js",
    "test": "jest",
    "test:unit": "jest --testPathPattern=tests/unit",
    "test:integration": "jest --testPathPattern=tests/integration",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "migrate:gamification": "node scripts/run-gamification-migration.js",
    "test:gamification": "node scripts/test-gamification.js",
    "setup:gamification": "npm run migrate:gamification && npm run test:gamification"
  },
  "dependencies": {
    "@azure/identity": "^4.0.0",
    "@azure/keyvault-secrets": "^4.7.0",
    "@sentry/node": "^7.100.0",
    "@sentry/profiling-node": "^1.3.0",
    "applicationinsights": "^2.9.0",
    "aws-sdk": "^2.1573.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "exifr": "^7.1.3",
    "express": "^4.22.1",
    "geolib": "^3.3.4",
    "morgan": "^1.10.1",
    "multer": "^1.4.5-lts.1",
    "multer-s3": "^2.10.0",
    "node-fetch": "^2.6.7",
    "piexifjs": "^1.0.6",
    "prom-client": "^15.1.0",
    "sharp": "^0.33.2",
    "sqlite3": "^5.1.7",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "axios": "^1.6.0",
    "colors": "^1.4.0",
    "jest": "^29.0.0",
    "nodemon": "^3.1.11",
    "supertest": "^6.0.0"
  },
  "jest": {
    "testEnvironment": "node"
  }
}
